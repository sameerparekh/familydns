#!/usr/bin/env bash
# Pre-push checks (<30s): full-tree formatting + type-check + lint.
# Compile/test runs in CI — kept out of here to stay under budget.
# To bypass in an emergency: git push --no-verify
set -euo pipefail

start=$(date +%s)
ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

fail=0

# ── Scala: scalafmt check across the whole repo ───────────────────────────
if command -v scalafmt >/dev/null 2>&1; then
  echo "pre-push: scalafmt --check (all .scala)"
  if ! scalafmt --check --non-interactive; then
    echo "pre-push: scalafmt failed. Run: scalafmt" >&2
    fail=1
  fi
else
  echo "pre-push: scalafmt not on PATH — skipping" >&2
fi

# ── Web: type-check + eslint on whole project ─────────────────────────────
if [[ -d web/node_modules ]]; then
  echo "pre-push: tsc --noEmit"
  if ! (cd web && npm run -s type-check); then
    fail=1
  fi
  echo "pre-push: eslint"
  if ! (cd web && npm run -s lint); then
    fail=1
  fi
else
  echo "pre-push: web/node_modules missing — skipping web checks" >&2
fi

end=$(date +%s)
echo "pre-push: $((end - start))s"
exit $fail
